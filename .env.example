# -----------------------------------------------------------------------------
# Application identity and startup
# These variables are read by app/infrastructure/config/settings.py.
# -----------------------------------------------------------------------------

# Human-readable application name exposed in logs and health payloads.
MODEL_TRAFFIC_MANAGER_APP_NAME=model-traffic-manager

# Runtime environment label used in logs and operator-facing diagnostics.
MODEL_TRAFFIC_MANAGER_ENVIRONMENT=local

# Bind address for local uvicorn startup.
MODEL_TRAFFIC_MANAGER_HOST=0.0.0.0

# Bind port for local uvicorn startup.
MODEL_TRAFFIC_MANAGER_PORT=8000

# Enable uvicorn reload mode for local development only.
MODEL_TRAFFIC_MANAGER_RELOAD=false

# Path to the router YAML config file mounted or available on disk.
MODEL_TRAFFIC_MANAGER_CONFIG_PATH=configs/example.router.yaml

# Base application log level.
MODEL_TRAFFIC_MANAGER_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional Azure Monitor / Application Insights observability
# Keep the default local path zero-dependency unless explicitly enabled.
# -----------------------------------------------------------------------------

# Supported values: local, azure_monitor
MODEL_TRAFFIC_MANAGER_OBSERVABILITY_BACKEND=local

# Optional explicit service version for exported telemetry resource attributes.
MODEL_TRAFFIC_MANAGER_APP_VERSION=0.1.0

# Router-owned connection string field. The standard
# APPLICATIONINSIGHTS_CONNECTION_STRING env var is also honored as a fallback.
MODEL_TRAFFIC_MANAGER_AZURE_MONITOR_CONNECTION_STRING=

# Export Python logs to Azure Monitor in addition to stdout. Traces remain the
# primary request-flow signal.
MODEL_TRAFFIC_MANAGER_AZURE_MONITOR_LOG_EXPORT_ENABLED=false

# Sampling ratio used by the Application Insights sampler when Azure Monitor is enabled.
MODEL_TRAFFIC_MANAGER_AZURE_MONITOR_SAMPLING_RATIO=1.0

# Disable Azure Monitor offline retry storage when pod-local filesystem buffering
# is not desired.
MODEL_TRAFFIC_MANAGER_AZURE_MONITOR_DISABLE_OFFLINE_STORAGE=false

# -----------------------------------------------------------------------------
# Outbound HTTP client tuning
# These values control connection pooling and timeout behavior for upstream calls.
# -----------------------------------------------------------------------------

# Maximum time allowed to establish the outbound TCP/TLS connection.
MODEL_TRAFFIC_MANAGER_OUTBOUND_CONNECT_TIMEOUT_MS=5000

# Maximum time allowed to write the outbound request body.
MODEL_TRAFFIC_MANAGER_OUTBOUND_WRITE_TIMEOUT_MS=30000

# Maximum time allowed to wait for a pooled outbound connection.
MODEL_TRAFFIC_MANAGER_OUTBOUND_POOL_TIMEOUT_MS=5000

# Total maximum concurrent outbound HTTP connections held by the shared client.
MODEL_TRAFFIC_MANAGER_OUTBOUND_MAX_CONNECTIONS=100

# Maximum keep-alive connections retained in the shared outbound pool.
MODEL_TRAFFIC_MANAGER_OUTBOUND_MAX_KEEPALIVE_CONNECTIONS=20

# -----------------------------------------------------------------------------
# Shared runtime state backend
# Switch between per-process local state and Redis-backed shared coordination.
# -----------------------------------------------------------------------------

# Supported values: in_memory, redis
MODEL_TRAFFIC_MANAGER_RUNTIME_STATE_BACKEND=in_memory

# Redis connection string. Required only when runtime_state_backend=redis.
MODEL_TRAFFIC_MANAGER_REDIS_URL=redis://localhost:6379/0

# Prefix applied to Redis keys used for health, half-open probes, and limiters.
MODEL_TRAFFIC_MANAGER_REDIS_KEY_PREFIX=router

# -----------------------------------------------------------------------------
# Local secret-ref examples
# The router resolves api_key secrets from env://ENV_VAR_NAME references in YAML.
# Add the concrete variables required by your own router config here.
# -----------------------------------------------------------------------------

# Example secret used by configs that reference env://UPSTREAM_API_KEY.
UPSTREAM_API_KEY=

# -----------------------------------------------------------------------------
# Higher-level Azure-backed local validation
# These variables are consumed by Make targets and scripts under scripts/release/.
# -----------------------------------------------------------------------------

# Shared environment profile used by integration-azure and AKS local runners.
ENVIRONMENT=dev1

# Optional override for the AKS version used by temporary higher-level test infra.
KUBERNETES_VERSION=

# Optional prebuilt image for e2e-aks runners. Leave empty to build and push automatically.
E2E_IMAGE=

# Namespace used by the AKS e2e runners.
E2E_NAMESPACE=e2e-router

# Name of the image-pull secret created in the test namespace for GHCR images.
E2E_IMAGE_PULL_SECRET_NAME=ghcr-pull

# Buildx platform used when the local runner builds and pushes the router image.
E2E_IMAGE_PLATFORM=linux/amd64

# Optional overrides for GHCR push/pull auth during local AKS validation.
GHCR_OWNER=
GHCR_USERNAME=
GHCR_TOKEN=

# Scope used by the integration-azure Managed Identity validation tests.
INTEGRATION_AZURE_SCOPE=https://management.azure.com/.default

# Optional overrides for the generated live-model router config.
E2E_ROUTER_TIMEOUT_MS=30000
E2E_ROUTER_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# Test-suite markers and runner-managed values
# These are usually exported by the local runner scripts or CI, not hand-written
# for day-to-day app startup. Keep them here for completeness and troubleshooting.
# -----------------------------------------------------------------------------

# Enables tests/integration_azure/.
RUN_INTEGRATION_AZURE=0

# Enables tests/integration_azure_chat/.
RUN_INTEGRATION_AZURE_CHAT=0

# Enables tests/integration_azure_embeddings/.
RUN_INTEGRATION_AZURE_EMBEDDINGS=0

# Enables tests/e2e_aks/.
RUN_E2E_AKS=0

# Enables tests/e2e_aks_live_model/.
RUN_E2E_AKS_LIVE_MODEL=0

# Enables tests/e2e_aks_live_embeddings/.
RUN_E2E_AKS_LIVE_EMBEDDINGS=0

# Enables tests/e2e_aks_live_load_balancing/.
RUN_E2E_AKS_LIVE_LOAD_BALANCING=0

# Enables tests/e2e_aks_live_shared_services/.
RUN_E2E_AKS_LIVE_SHARED_SERVICES=0

# Enables tests/e2e_aks_live_observability/.
RUN_E2E_AKS_LIVE_OBSERVABILITY=0

# Enables tests/e2e_aks_redis/.
RUN_E2E_AKS_REDIS=0

# Base URL used by AKS e2e test suites after port-forward is established.
E2E_BASE_URL=http://127.0.0.1:18080

# Replica-specific base URLs used by the Redis-backed multi-replica AKS suite.
E2E_BASE_URL_REPLICA_A=
E2E_BASE_URL_REPLICA_B=

# Path to the Terraform outputs JSON used by the live-model suite.
E2E_LIVE_MODEL_OUTPUTS_JSON=

# Path to the Terraform outputs JSON used by the live embeddings suite.
E2E_LIVE_EMBEDDINGS_OUTPUTS_JSON=

# Path to the Terraform outputs JSON used by the live shared-services suite.
E2E_LIVE_SHARED_SERVICES_OUTPUTS_JSON=

# Path to the Terraform outputs JSON used by the live observability suite.
E2E_LIVE_OBSERVABILITY_OUTPUTS_JSON=

# Path to the Terraform outputs JSON used by the integration-azure chat suite.
INTEGRATION_AZURE_CHAT_OUTPUTS_JSON=

# Path to the Terraform outputs JSON used by the integration-azure embeddings suite.
INTEGRATION_AZURE_EMBEDDINGS_OUTPUTS_JSON=

# User-assigned identity client ID injected into AKS service-account templates.
E2E_UAI_CLIENT_ID=

# Artifact directory for the currently running validation suite.
VALIDATION_ARTIFACTS_DIR=

# Workload Identity token file injected by the AKS runtime. Normally platform-managed.
AZURE_FEDERATED_TOKEN_FILE=
