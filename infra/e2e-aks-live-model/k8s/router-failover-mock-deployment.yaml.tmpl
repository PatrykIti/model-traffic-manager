apiVersion: apps/v1
kind: Deployment
metadata:
  name: router-failover-mock
  namespace: ${E2E_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: router-failover-mock
  template:
    metadata:
      labels:
        app: router-failover-mock
    spec:
      serviceAccountName: router-app
      containers:
        - name: mock
          image: ${E2E_IMAGE}
          imagePullPolicy: Always
          command: ["/app/.venv/bin/python", "-c"]
          args:
            - |
              import json
              from http.server import BaseHTTPRequestHandler, HTTPServer

              class Handler(BaseHTTPRequestHandler):
                  def do_POST(self):
                      if self.path == "/rate-limit":
                          self.send_response(429)
                          self.send_header("Content-Type", "application/json")
                          self.send_header("Retry-After", "30")
                          self.end_headers()
                          self.wfile.write(json.dumps({"error": "rate_limited"}).encode("utf-8"))
                          return
                      if self.path == "/unhealthy":
                          self.send_response(503)
                          self.send_header("Content-Type", "application/json")
                          self.end_headers()
                          self.wfile.write(json.dumps({"error": "unhealthy"}).encode("utf-8"))
                          return
                      self.send_response(404)
                      self.send_header("Content-Type", "application/json")
                      self.end_headers()
                      self.wfile.write(json.dumps({"error": "not_found"}).encode("utf-8"))

                  def log_message(self, format, *args):
                      return

              HTTPServer(("0.0.0.0", 8080), Handler).serve_forever()
          ports:
            - containerPort: 8080
              name: http
          readinessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 3
            periodSeconds: 5
          livenessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 3
            periodSeconds: 10
